# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_PATH=cornell_demo.db

# OpenAI + Tavily for link ingestion and enrichment
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# Ramp API (demo assumes credentials grant card provisioning access)
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=
RAMP_TOKEN_URL=https://api.ramp.com/developer/v1/token
RAMP_API_BASE_URL=https://api.ramp.com/developer/v1

# Optional: comma-separated email list for recruiting card notifications
DEFAULT_RECRUITING_STAFF_EMAILS=coach@cornellwrestling.org,ops@cornellwrestling.org
